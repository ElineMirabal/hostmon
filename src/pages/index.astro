---
//@ts-nocheck
import Layout from "../layouts/Layout.astro";
import Kunstner from "../components/Kunstnere.astro";
import Vendertilbagecard from "../components/Vendertilbagecard.astro";
import Informationscardsindex from "../components/informationscardsindex.astro";

const url =`${import.meta.env.SUPABASE_URL}/rest/v1/kunstnere?select=*`;
const apiKey = import.meta.env.SUPABASE_PUBLISHABLE_KEY; 

console.log("TEST", import.meta.env.SUPABASE_URL);

const data = await fetch(url, {
  headers: {
    "Content-Type": "application/json",
    "apikey": apiKey,
    "Authorization": `Bearer ${apiKey}`
  }
}).then(res => res.json());

console.log(data);

---
<Layout>

	{data.map((kunstner) => <Kunstner kunstner={kunstner} />)}	

<Vendertilbagecard />
<Informationscardsindex />
</Layout>




<script></script>
