---


<a href="" class="cta-laes-mere">
  Læs mere
</a>
<a href="/kunstnereoversigt#billetter" class="cta-billetterbilletter">
  Billetter Billetter
</a>
<a href="/kunstnereoversigt#billetter" class="cta-kob-billetter">
  Køb Billetter
</a>
<a href="index.astro"class="cta-send">
  Send
</a>
<button id="openModal">Her</button>

<style>
.cta {
text-align: center;
margin-top: 20px;
margin-bottom: 20px;
}

  #openModal, .cta-laes-mere, .cta-send {
  display: inline-block;
  padding: 5px 30px;
  background-color: #0a0a0a;
  color: white;
  text-decoration: none;
  border: 2px solid white;
  border-radius: 50px;
  font-weight: bold;
}

.cta-billetterbilletter, .cta-kob-billetter{
 color: #261321;
padding: 15px 30px;
font-size: 18px;
font-weight: 600;
border: white solid 2px;
border-radius: 50%;
}

#openModal, .cta-billetterbilletter, .cta-kob-billetter:hover, .cta-laes-mere, .cta-send {
  background-color: #9B8EFF;
  font-weight: bold;
}

</style>

  
   
