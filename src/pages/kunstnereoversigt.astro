---
//@ts-nocheck
import Layout from "../layouts/Layout.astro";
import Kunstner from "../components/Kunstnere.astro";
import Cta from "../components/Cta.astro";

const url =`${import.meta.env.SUPABASE_URL}/rest/v1/kunstnere?select=*`;
const apiKey = import.meta.env.SUPABASE_PUBLISHABLE_KEY; 


const data = await fetch(url, {
  headers: {
    "Content-Type": "application/json",
    "apikey": apiKey,
    "Authorization": `Bearer ${apiKey}`
  }
}).then(res => res.json());

console.log(data);

---

<CTA href="/kontakt" text="Kontakt os" />
<CTA href="/om-os" text="Læs mere" />


