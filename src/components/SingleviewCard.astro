---
const { title, day, time, tekst, billede } = Astro.props;
---

<div class="card">
  <h2>{title}</h2>

  <div class="meta">
    <span>{day}</span>
    <span>{time}</span>
  </div>

  <img src={billede} alt={title} />

  <p>{tekst}</p>

  <div class="buttons">
    <a href="#">Billetter</a>
    <a href="#">Billet</a>
  </div>
</div>

<style>
.SingleviewCard {
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(10px);
  padding: 2rem;
  border-radius: 20px;
  color: white;
  max-width: 500px;
  margin: 0 auto;
  text-align: center;
}

.meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 1rem;
  opacity: 0.8;
}

.card img {
  width: 100%;
  border-radius: 10px;
  margin: 1rem 0;
}

.buttons {
  display: flex;
  justify-content: center;
  gap: 1rem;
  margin-top: 1rem;
}

.buttons a {
  border: 1px solid white;
  padding: 0.5rem 1.5rem;
  border-radius: 999px;
  text-decoration: none;
  color: white;
  transition: 0.2s;
}

.buttons a:hover {
  background: white;
  color: black;
}
</style>