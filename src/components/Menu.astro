<nav class="nav">
     <div class="logo">
            <a href="/">
                <img src="/billeder/logo.svg" alt="Logo">
            </a>
        </div>
  
   <div class="burger">≡</div>

  <ul class="menu">
    <li><a href="/kunstnereoversigt">Billetter</a></li>
    <li><a href="/kunstnereoversigt">Program</a></li>
    <li><a href="/">Om os</a></li>
  </ul>
</nav>



<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const burger = document.querySelector(".nav .burger");
    const menu = document.querySelector(".nav .menu");

    if (burger && menu) {
      burger.addEventListener("click", () => {
        console.log("klik virker");
        menu.classList.toggle("open");
      });
    }
  });
</script>



<style>
  .nav {
    width: 90%;
    padding: 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: white;
    z-index: 90;
  }

  .logo {
    font-weight: bold;
  }

  .burger {
    font-size: 1.8rem;
    cursor: pointer;
    position: relative;
    z-index: 90;
      background: transparent;
    border: none;
    color: inherit;
    pointer-events: auto;
  }

  

  /*MOBIL*/
  .menu {
    position: absolute;
    top: 70px;
    right: 0;
    width: 100%;
    display: none;
    flex-direction: column;
    text-align: center;
    font-family: Arial, Helvetica, sans-serif;
    background: black;
    z-index: 90;
  }

  .menu li {
    padding: 1rem;
    list-style: none;
    justify-content: center;
  }

  .menu a {
    color: white;
    text-decoration: none;
  }

  .menu.open {
    display: flex;
  }

  .logo img{
    width: 50%;
  }

  /*DESKTOP*/
  @media (min-width: 840px) {
    .menu {
      position: static;
      display: flex;
      flex-direction: row;
      background: none;
      width: auto;
      gap: 2rem;
    }

    .burger {
      display: block; 
    }
  }
</style>
