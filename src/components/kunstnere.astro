---
//@ts-nocheck
const { kunstner } = Astro.props;
---

<article class="card">
  <img src={kunstner.billede} alt={kunstner.navn} />

  <!-- standard -->
  <div class="standard">
    <h2>{kunstner.navn}</h2>
  </div>

  <!-- hover -->
  <div class="overlay">
    <h2>{kunstner.navn}</h2>
    <p>{kunstner.tid}</p>
    <a href={`/singleview/${kunstner.id}`}>Se kunstner</a>
  </div>
</article>

<style>
.card {
  position: relative;
  width: 300px;
  height: 400px;
  overflow: hidden;
}

.card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.card:hover img {
  transform: scale(1.05);
}

.standard{
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 1rem;
  color: white;
  background: linear-gradient(
    to top,
    rgba(0, 0, 0, 0.7),
    transparent
  );
  opacity: 1;
  transition: opacity 0.3s ease;
}
.card:hover .standard {
  opacity: 0;
}

/* hover overlay */
.overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: white;
  background: rgba(0, 0, 0, 0.6);
  opacity: 0;
  transition: opacity 0.3s ease;
}

/* hover aktivering */
.card:hover .overlay {
  opacity: 1;
}
</style>
